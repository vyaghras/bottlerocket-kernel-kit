# Architecture-specific configurations for x86_64

# x86_64-specific crypto acceleration
CONFIG_CRYPTO_SHA256_SSSE3=y
CONFIG_CRYPTO_SHA512_SSSE3=y

# x86_64-specific network features
CONFIG_E1000E_HWTS=y
CONFIG_MYRI10GE_DCA=y
# CONFIG_ICE_HWTS is not set

# x86_64-specific EFI support
CONFIG_EFI_MIXED=y

# x86_64-specific hardware support
CONFIG_VMD=y

# x86_64-specific input devices
CONFIG_SERIO_I8042=m

# x86_64-specific mouse drivers
# CONFIG_MOUSE_PS2_LIFEBOOK is not set
# CONFIG_MOUSE_PS2_VMMOUSE is not set

# x86_64-specific network drivers
CONFIG_INFINIBAND_USNIC=m

# x86_64-specific virtualization
CONFIG_XEN_BLKDEV_FRONTEND=y
